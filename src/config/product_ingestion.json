{
  "ingestion_type": "load_file",
  "source": {
    "path": "dbfs:/Volumes/sandbox/default/sales/Products.csv",
    "format": "CSV"
  },
  "target": {
    "table": "dev.bronze_products"
  },
  "audit": {
    "table": "dev.silver_ingestion_audit"
  },
  "format_options": {
    "sheetName": "Products",
    "header": "true",
    "inferSchema": "true"
  },
  "transformations": [
    {
      "type": "rename",
      "source_column": "Price per product",
      "target_column": "price_per_product"
    },
    {
      "type": "rename",
      "source_column": "Category",
      "target_column": "category"
    },
    {
      "type": "rename",
      "source_column": "Sub-Category",
      "target_column": "subcategory"
    },
    {
      "type": "rename",
      "source_column": "State",
      "target_column": "state"
    },
    {
      "type": "rename",
      "source_column": "Product ID",
      "target_column": "product_id"
    },
    {
      "type": "rename",
      "source_column": "Product Name",
      "target_column": "product_name"
    }
  ],
  "write_options": {
    "mergeSchema": "true"
  },
  "metadata_columns": {
    "ingestion_timestamp": true,
    "source_file_name": true,
    "load_date": true,
    "run_id": true
  }
}