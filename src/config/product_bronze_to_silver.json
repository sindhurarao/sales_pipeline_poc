{
  "pre_processing": {
    "deduplication": {
      "enabled": true,
      "keys": ["product_id"],
      "order_by": [
        {
          "column": "ingestion_timestamp",
          "direction": "desc"
        }
      ],
      "strategy": "row_number",
      "keep": "latest"
    }
  },
  "ingestion_type": "table",
  "source": {
    "table": "dev.bronze_products"
  },
  "validation": {
    "enabled": true,
    "rules_table": "dev.silver_product_rules",
    "quarantine_table": "dev.silver_product_quarantine"
  },
  "transformations": [
    {
      "type": "rename",
      "source_column": "price_per_product",
      "target_column": "standard_price"
    },
    {
      "type": "rename",
      "source_column": "subcategory",
      "target_column": "sub_category"
    },
    {
      "type": "try_cast",
      "datatype": "double",
      "target_column": "standard_price"
    },
    {
      "type": "expression",
      "target_column": "effective_date",
      "expression": "current_date()"
    },
    {
      "type": "expression",
      "target_column": "expiry_date",
      "expression": "CAST('9999-12-31' AS DATE)"
    },
    {
      "type": "expression",
      "target_column": "current_flag",
      "expression": "true"
    }
  ],
  "target": {
    "table": "dev.silver_dim_product"
  },
  "write_options": {
    "mode": "append"
  },
  "audit": {
    "table": "dev.silver_ingestion_audit"
  }
}