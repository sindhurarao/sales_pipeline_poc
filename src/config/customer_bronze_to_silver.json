{
  "pre_processing": {
    "deduplication": {
      "enabled": true,
      "keys": ["customer_id"],
      "order_by": [
        {
          "column": "ingestion_timestamp",
          "direction": "desc"
        }
      ],
      "strategy": "row_number",
      "keep": "latest"
    }
  },
  "ingestion_type": "table",
  "source": {
    "table": "dev.bronze_customers"
  },
  "validation": {
    "enabled": true,
    "rules_table": "dev.silver_customer_rules",
    "quarantine_table": "dev.silver_customer_quarantine"
  },
  "transformations": [
    {
      "type": "rename",
      "source_column": "name",
      "target_column": "customer_name"
    },

    {
      "type": "expression",
      "target_column": "effective_date",
      "expression": "current_date()"
    },
    {
      "type": "expression",
      "target_column": "expiry_date",
      "expression": "CAST('9999-12-31' AS DATE)"
    },
    {
      "type": "expression",
      "target_column": "current_flag",
      "expression": "true"
    },
    {
      "type": "select",
      "columns": [
        "customer_id",
        "customer_name",
        "segment",
        "country",
        "region",
        "state",
        "city",
        "postal_code",
        "effective_date",
        "expiry_date",
        "current_flag"
      ]
    }
  ],
  "target": {
    "table": "dev.silver_dim_customer"
  },
  "write_options": {
    "mode": "scd2_merge",
    "businessKeys": ["customer_id"],
    "changeColumns": [
      "customer_name",
      "segment",
      "country",
      "region",
      "state",
      "city",
      "postal_code"
    ],
    "effectiveDateColumn": "effective_date",
    "expiryDateColumn": "expiry_date",
    "currentFlagColumn": "current_flag",
    "activeExpiryDate": "9999-12-31"
  },
  "audit": {
    "table": "dev.silver_ingestion_audit"
  }
}